local function refreshWhitelistUI()
    local searchText = string.lower(searchBox.Text)
    
    -- Clear current list
    for _, child in ipairs(wlScroll:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        
        -- Filter logic
        local nameMatch = string.find(string.lower(player.Name), searchText)
        local displayMatch = string.find(string.lower(player.DisplayName), searchText)
        
        if searchText ~= "" and not nameMatch and not displayMatch then continue end
        
        -- Create entry
        local pBtn = Instance.new("TextButton")
        pBtn.Size = UDim2.new(1, -10, 0, 40)
        pBtn.BackgroundColor3 = aimbotWhitelist[player.UserId] and COLOR_ON or COLOR_OFF
        -- Label format: Username (@DisplayName)
        pBtn.Text = player.Name .. "\n(@" .. player.DisplayName .. ")"
        pBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        pBtn.Font = Enum.Font.GothamBold
        pBtn.TextSize = 10
        pBtn.TextWrapped = true
        pBtn.Parent = wlScroll
        
        Instance.new("UICorner", pBtn).CornerRadius = UDim.new(0, 4)
        
        pBtn.MouseButton1Click:Connect(function()
            aimbotWhitelist[player.UserId] = not aimbotWhitelist[player.UserId]
            animateElement(pBtn, aimbotWhitelist[player.UserId] and COLOR_ON or COLOR_OFF)
        end)
    end
    wlScroll.CanvasSize = UDim2.new(0, 0, 0, wlLayout.AbsoluteContentSize.Y)
end

searchBox:GetPropertyChangedSignal("Text"):Connect(refreshWhitelistUI)
Players.PlayerAdded:Connect(refreshWhitelistUI)
Players.PlayerRemoving:Connect(refreshWhitelistUI)

local function toggleWhitelist(btn)
    whiteListFrame.Visible = not whiteListFrame.Visible
    btn.Text = whiteListFrame.Visible and "YOUR GANG: OPEN" or "YOUR GANG: CLOSED"
    animateElement(btn, whiteListFrame.Visible and COLOR_ON or COLOR_OFF)
    if whiteListFrame.Visible then refreshWhitelistUI() end
end
