-- 3. PERSISTENT ESP ENGINE (FIXED)
----------------------------------------------------------------
local isEspActive = false

local function createVisuals(player)
    if player == LocalPlayer or not player.Character then return end
    local char = player.Character
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    -- Ensure Highlight exists
    if not char:FindFirstChild("PlayerHighlight") then
        local highlight = Instance.new("Highlight")
        highlight.Name = "PlayerHighlight"
        highlight.FillColor = Color3.fromRGB(138, 43, 226)
        highlight.FillTransparency = 0.5
        highlight.OutlineColor = Color3.fromRGB(200, 150, 255)
        highlight.OutlineTransparency = 0
        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        highlight.Parent = char
    end

    -- Ensure BillboardGui exists
    if not root:FindFirstChild("PlayerESP") then
        local billboard = Instance.new("BillboardGui")
        billboard.Name = "PlayerESP"
        billboard.AlwaysOnTop = true
        billboard.Size = UDim2.new(0, 200, 0, 50)
        billboard.StudsOffset = Vector3.new(0, 3, 0)
        billboard.Adornee = root
        billboard.Parent = root

        local textLabel = Instance.new("TextLabel")
        textLabel.Size = UDim2.new(1, 0, 1, 0)
        textLabel.BackgroundTransparency = 1
        textLabel.Text = player.Name
        textLabel.TextColor3 = Color3.fromRGB(200, 150, 255)
        textLabel.TextSize = 12
        textLabel.Font = Enum.Font.GothamBold
        textLabel.TextStrokeTransparency = 0
        textLabel.Parent = billboard
    end
end

-- The Heartbeat loop ensures ESP is always re-applied if it gets deleted
RunService.Heartbeat:Connect(function()
    if isEspActive then
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                createVisuals(player)
            end
        end
    end
end)

local function toggleEsp(btn)
    isEspActive = not isEspActive
    if isEspActive then
        btn.Text = "ESP: ON"
        animateElement(btn, COLOR_ON)
    else
        btn.Text = "ESP: OFF"
        animateElement(btn, COLOR_OFF)
        -- Cleanup
        for _, player in ipairs(Players:GetPlayers()) do
            if player.Character then
                local root = player.Character:FindFirstChild("HumanoidRootPart")
                if root and root:FindFirstChild("PlayerESP") then root.PlayerESP:Destroy() end
                if player.Character:FindFirstChild("PlayerHighlight") then player.Character.PlayerHighlight:Destroy() end
            end
        end
    end
end
----------------------------------------------------------------
-- 4. EXACT AUTO-AIM LOGIC (WITH WHITELIST)
----------------------------------------------------------------

local isAiming = false
local aimConnection = nil
local targetBodyPart = "Head" 

local function getClosestPlayer()
    local closestPlayer = nil
    local shortestDistance = math.huge
    local localChar = LocalPlayer.Character
    local localRoot = localChar and localChar:FindFirstChild("HumanoidRootPart")

    if not localRoot then return nil end

    for _, player in ipairs(Players:GetPlayers()) do
        -- Check if player is NOT us, AND they are NOT in the whitelist
        if player ~= LocalPlayer and not aimbotWhitelist[player.UserId] and player.Character then
            local humanoid = player.Character:FindFirstChild("Humanoid")
            local targetPart = player.Character:FindFirstChild(targetBodyPart) or player.Character:FindFirstChild("HumanoidRootPart")
            
            if humanoid and humanoid.Health > 0 and targetPart then
                local distance = (targetPart.Position - localRoot.Position).Magnitude
                if distance < shortestDistance then
                    closestPlayer = player.Character
                    shortestDistance = distance
                end
            end
        end
    end
    return closestPlayer
end

local function toggleAim(btn)
    isAiming = not isAiming
    if isAiming then
        btn.Text = "AIMBOT: ON"
        animateElement(btn, COLOR_ON)
        
        aimConnection = RunService.RenderStepped:Connect(function()
            local target = getClosestPlayer()
            if target then
                local partToAimAt = target:FindFirstChild(targetBodyPart) or target:FindFirstChild("HumanoidRootPart")
                if partToAimAt then
                    Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, partToAimAt.Position)
                end
            end
        end)
    else
        btn.Text = "AIMBOT: OFF"
        animateElement(btn, COLOR_OFF)
        if aimConnection then aimConnection:Disconnect(); aimConnection = nil end
    end
end
----------------------------------------------------------------
-- 5. PREMIUM FLIGHT SYSTEM
----------------------------------------------------------------

local isFlying = false
local flySpeed = 75
local flyConnection = nil

local function toggleFly(btn)
    local char = LocalPlayer.Character
    local rootPart = char and char:FindFirstChild("HumanoidRootPart")
    local humanoid = char and char:FindFirstChild("Humanoid")

    if not rootPart or not humanoid then return end

    isFlying = not isFlying

    if isFlying then
        btn.Text = "FLY: ON"
        animateElement(btn, COLOR_ON)
        humanoid.PlatformStand = true

        local bodyVelocity = Instance.new("BodyVelocity")
        bodyVelocity.Name = "RevoxFlyVelocity"
        bodyVelocity.MaxForce = Vector3.new(100000, 100000, 100000)
        bodyVelocity.Velocity = Vector3.new(0, 0, 0)
        bodyVelocity.Parent = rootPart

        local bodyGyro = Instance.new("BodyGyro")
        bodyGyro.Name = "RevoxFlyGyro"
        bodyGyro.MaxTorque = Vector3.new(100000, 100000, 100000)
        bodyGyro.P = 10000
        bodyGyro.Parent = rootPart

        flyConnection = RunService.RenderStepped:Connect(function()
            if not isFlying or not char then return end
            bodyGyro.CFrame = Camera.CFrame
            local moveVector = Vector3.new(0, 0, 0)
            
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveVector = moveVector + Camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveVector = moveVector - Camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveVector = moveVector - Camera.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveVector = moveVector + Camera.CFrame.RightVector end
            
            if moveVector.Magnitude > 0 then
                bodyVelocity.Velocity = moveVector.Unit * flySpeed
            else
                bodyVelocity.Velocity = Vector3.new(0, 0, 0)
            end
        end)
    else
        btn.Text = "FLY: OFF"
        animateElement(btn, COLOR_OFF)
        humanoid.PlatformStand = false
        if rootPart:FindFirstChild("RevoxFlyVelocity") then rootPart.RevoxFlyVelocity:Destroy() end
        if rootPart:FindFirstChild("RevoxFlyGyro") then rootPart.RevoxFlyGyro:Destroy() end
        if flyConnection then flyConnection:Disconnect(); flyConnection = nil end
    end
end

