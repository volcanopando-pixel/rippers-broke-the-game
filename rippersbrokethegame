    keyBtn.Name = "Keybind"
    keyBtn.Size = UDim2.new(0, 42, 1, 0)
    keyBtn.Position = UDim2.new(1, -42, 0, 0)
    keyBtn.BackgroundColor3 = COLOR_KEYBIND
    keyBtn.Text = "***"
    keyBtn.TextColor3 = Color3.fromRGB(200, 180, 255)
    keyBtn.TextSize = 14
    keyBtn.Font = Enum.Font.GothamBlack
    keyBtn.BorderSizePixel = 0
    keyBtn.Parent = row

    local keyCorner = Instance.new("UICorner")
    keyCorner.CornerRadius = UDim.new(0, 4)
    keyCorner.Parent = keyBtn

    local keyStroke = Instance.new("UIStroke")
    keyStroke.Thickness = 1
    keyStroke.Color = Color3.fromRGB(90, 60, 130)
    keyStroke.Parent = keyBtn

    local isListening = false
    local assignedKey = nil

    btn.MouseButton1Click:Connect(function() toggleLogic(btn) end)

    keyBtn.MouseButton1Click:Connect(function()
        isListening = true
        keyBtn.Text = "..."
        keyBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        animateElement(keyBtn, Color3.fromRGB(100, 70, 150))
    end)

    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if isListening and input.UserInputType == Enum.UserInputType.Keyboard then
            assignedKey = input.KeyCode
            local keyName = input.KeyCode.Name
            if keyName:len() > 5 then keyName = string.sub(keyName, 1, 5) end
            keyBtn.Text = string.upper(keyName)
            keyBtn.TextColor3 = Color3.fromRGB(200, 180, 255)
            animateElement(keyBtn, COLOR_KEYBIND)
            isListening = false
            return
        end
        if not gameProcessed and assignedKey and input.KeyCode == assignedKey then
            toggleLogic(btn)
        end
    end)

    return btn
end

